# Force LF line endings for all text files (required for Lovable/Linux build)
* text=auto eol=lf

# Explicitly declare binary files to prevent line ending conversion
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
*.otf binary

# bun.lock and package-lock.json are text files — keep LF
bun.lock text eol=lf
package-lock.json text eol=lf

# SVG as text so line endings are normalized
*.svg text eol=lf
